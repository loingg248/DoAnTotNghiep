<Window x:Class="SystemMonitor.SolutionGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hướng dẫn chi tiết" Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Guide Content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="GuideContent" 
                       TextWrapping="Wrap" 
                       FontFamily="Consolas"
                       FontSize="12"
                       LineHeight="20"
                       Padding="10"/>
        </ScrollViewer>

        <!-- Close Button -->
        <Button Grid.Row="1" 
                Content="Đóng" 
                HorizontalAlignment="Right" 
                Width="80" Height="30" 
                Margin="0,10,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>