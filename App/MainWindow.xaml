<Window x:Class="SystemMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:lv="clr-namespace:LiveCharts;assembly=LiveCharts"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="Giám sát Hệ thống" Height="780" Width="1000"
        Closing="MainWindow_Closing"
        Background="#FFF0F2F5" FontFamily="Segoe UI" FontSize="13"
        >

    <Window.Resources>
        <tb:TaskbarIcon x:Key="NotifyIcon"
                        IconSource="/icon.ico"
                        ToolTipText="Giám sát Hệ thống - Đang chạy nền"
                        Visibility="Collapsed"
                        DoubleClickCommand="{Binding ShowWindowCommand}"
                        MenuActivation="RightClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Hiển thị Giám sát" Click="ShowMonitor_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🖥️" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Cài đặt Cảnh báo" Click="ShowAlertSettings_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="⚠️" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Thoát" Click="ExitApplication_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="❌" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
        <!-- Card style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Direction="270" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button style -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF1976D2"/>
            <Setter Property="BorderBrush" Value="#FF1976D2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="6"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" 
                                BorderThickness="0,0,0,2" BorderBrush="Transparent" 
                                Margin="{TemplateBinding Margin}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" 
                                              HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#1976D2"/>
                                <Setter Property="Foreground" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1976D2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Chart Card Style -->
        <Style x:Key="ChartCardStyle" TargetType="lvc:CartesianChart">
            <Setter Property="Height" Value="180"/>
            <Setter Property="MinHeight" Value="150"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="DisableAnimations" Value="False"/>
            <Setter Property="Hoverable" Value="True"/>
            <Setter Property="AnimationsSpeed" Value="00:00:00.8"/>
            <Setter Property="Background" Value="#FAFBFC"/>
        </Style>

        <Style x:Key="SolutionButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            CornerRadius="4"
                            BorderThickness="1"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel>
        <Border x:Name="WarningBorder" 
        DockPanel.Dock="Top" 
        Margin="15,10,15,10" 
        Padding="15,10" 
        CornerRadius="8"
        Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="WarningStatus" 
                   Text="Hệ thống đang hoạt động bình thường" 
                   FontWeight="SemiBold" 
                   VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tab Control for different pages -->
        <TabControl Margin="10" BorderThickness="0" Background="Transparent">
            <TabItem Header="🖥️ Thông tin Hệ thống" Style="{StaticResource TabButtonStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Control buttons moved here -->
                        <StackPanel Orientation="Horizontal" Margin="15" HorizontalAlignment="Left">
                            <Button Content="🔄 Làm mới" Width="110" Click="RefreshButton_Click"/>
                            <Button Content="▶ Bắt đầu Giám sát" Width="140" Click="StartMonitorButton_Click"/>
                            <Button Content="⏹ Dừng Giám sát" Width="140" Click="StopMonitorButton_Click"/>
                        </StackPanel>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- CPU Card -->
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="🖥 Bộ xử lý" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="CpuName" Text="Tên CPU: " Margin="0,3"/>
                                    <TextBlock x:Name="CpuTemp" Text="Nhiệt độ CPU: " Margin="0,3"/>
                                    <TextBlock x:Name="CpuLoad" Text="Sử dụng CPU: " Margin="0,3"/>
                                    <TextBlock x:Name="CpuClock" Text="Tần số CPU: " Margin="0,3"/>

                                    <!-- CPU Chart -->
                                    <lvc:CartesianChart x:Name="CpuChart" Style="{StaticResource ChartCardStyle}">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="" ShowLabels="False" Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="%" MinValue="0" MaxValue="100" 
              LabelFormatter="{Binding YFormatter}"
              Separator="{x:Static lvc:DefaultAxes.CleanSeparator}">
                                                <lvc:Axis.Sections>
                                                    <lvc:AxisSection Value="0" SectionWidth="30" Fill="#E8F5E8"/>
                                                    <lvc:AxisSection Value="30" SectionWidth="40" Fill="#FFF3CD"/>
                                                    <lvc:AxisSection Value="70" SectionWidth="30" Fill="#F8D7DA"/>
                                                </lvc:Axis.Sections>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.Series>
                                            <lvc:LineSeries Values="{Binding CpuValues}" 
                        StrokeThickness="3" 
                        PointGeometrySize="6"
                        Fill="#331976D2"
                        Stroke="#1976D2"/>
                                        </lvc:CartesianChart.Series>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>

                            <!-- RAM Card -->
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="💾 Bộ nhớ" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="RamTotal" Text="Tổng RAM: " Margin="0,3"/>
                                    <TextBlock x:Name="RamUsed" Text="RAM đã sử dụng: " Margin="0,3"/>
                                    <TextBlock x:Name="RamAvailable" Text="RAM còn lại: " Margin="0,3"/>
                                    <TextBlock x:Name="RamUsage" Text="Sử dụng RAM: " Margin="0,3"/>

                                    <!-- RAM Chart -->
                                    <lvc:CartesianChart x:Name="RamChart" Style="{StaticResource ChartCardStyle}">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="" ShowLabels="False" Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="%" MinValue="0" MaxValue="100" 
              LabelFormatter="{Binding YFormatter}"
              Separator="{x:Static lvc:DefaultAxes.CleanSeparator}">
                                                <lvc:Axis.Sections>
                                                    <lvc:AxisSection Value="0" SectionWidth="50" Fill="#E8F5E8"/>
                                                    <lvc:AxisSection Value="50" SectionWidth="30" Fill="#FFF3CD"/>
                                                    <lvc:AxisSection Value="80" SectionWidth="20" Fill="#F8D7DA"/>
                                                </lvc:Axis.Sections>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.Series>
                                            <lvc:LineSeries Values="{Binding RamValues}" 
                        StrokeThickness="3" 
                        PointGeometrySize="6"
                        Fill="#334CAF50"
                        Stroke="#4CAF50"/>
                                        </lvc:CartesianChart.Series>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>

                            <!-- GPU Card -->
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardStyle}">
                                <StackPanel x:Name="GpuContainer" Grid.Row="2" Grid.Column="1" Margin="10,10,10,10">
                                    <TextBlock Text="🎮 Card đồ họa" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="GpuName" Text="Tên GPU: " Margin="0,3"/>
                                    <TextBlock x:Name="GpuTemp" Text="Nhiệt độ GPU: " Margin="0,3"/>
                                    <TextBlock x:Name="GpuLoad" Text="Sử dụng GPU: " Margin="0,3"/>
                                    <TextBlock x:Name="GpuMemory" Text="Bộ nhớ GPU: " Margin="0,3"/>

                                    <!-- GPU Chart -->
                                    <lvc:CartesianChart x:Name="GpuChart" Style="{StaticResource ChartCardStyle}">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="" ShowLabels="False" Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="%" MinValue="0" MaxValue="100" 
              LabelFormatter="{Binding YFormatter}"
              Separator="{x:Static lvc:DefaultAxes.CleanSeparator}">
                                                <lvc:Axis.Sections>
                                                    <lvc:AxisSection Value="0" SectionWidth="30" Fill="#E8F5E8"/>
                                                    <lvc:AxisSection Value="30" SectionWidth="40" Fill="#FFF3CD"/>
                                                    <lvc:AxisSection Value="70" SectionWidth="30" Fill="#F8D7DA"/>
                                                </lvc:Axis.Sections>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.Series>
                                            <lvc:LineSeries Values="{Binding GpuValues}" 
                        StrokeThickness="3" 
                        PointGeometrySize="6"
                        Fill="#33FF9800"
                        Stroke="#FF9800"/>
                                        </lvc:CartesianChart.Series>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>

                            <!-- Disk Card -->
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="💽 Ổ cứng" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="DiskName" Text="Tên ổ cứng: " Margin="0,3"/>
                                    <TextBlock x:Name="DiskTemp" Text="Nhiệt độ ổ cứng: " Margin="0,3"/>
                                    <TextBlock x:Name="DiskActivity" Text="Hoạt động ổ cứng: " Margin="0,3"/>
                                    <TextBlock x:Name="DiskSpace" Text="Dung lượng ổ cứng: " Margin="0,3"/>

                                    <!-- Disk Chart -->
                                    <lvc:CartesianChart x:Name="DiskChart" Style="{StaticResource ChartCardStyle}">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="" ShowLabels="False" Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="%" MinValue="0" MaxValue="100" 
              LabelFormatter="{Binding YFormatter}"
              Separator="{x:Static lvc:DefaultAxes.CleanSeparator}">
                                                <lvc:Axis.Sections>
                                                    <lvc:AxisSection Value="0" SectionWidth="50" Fill="#E8F5E8"/>
                                                    <lvc:AxisSection Value="50" SectionWidth="30" Fill="#FFF3CD"/>
                                                    <lvc:AxisSection Value="80" SectionWidth="20" Fill="#F8D7DA"/>
                                                </lvc:Axis.Sections>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.Series>
                                            <lvc:LineSeries Values="{Binding DiskValues}" 
                        StrokeThickness="3" 
                        PointGeometrySize="6"
                        Fill="#339C27B0"
                        Stroke="#9C27B0"/>
                                        </lvc:CartesianChart.Series>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="⚙️ Cài đặt Nguồn điện" Style="{StaticResource TabButtonStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <TextBlock Text="⚙️" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Quản lý Nguồn điện" FontSize="22" FontWeight="Bold" Foreground="#1976D2"/>
                                <TextBlock Text="Tối ưu hóa mức tiêu thụ điện năng và hiệu suất hệ thống" 
                               FontSize="13" Foreground="#666" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Power Plan Card -->
                            <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="🔋" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Chế độ Nguồn" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <ComboBox x:Name="PowerPlanComboBox" 
                                  SelectionChanged="PowerPlanComboBox_SelectionChanged"
                                  Margin="0,0,0,10"/>

                                    <TextBlock Text="Chọn chế độ nguồn phù hợp nhất với cách sử dụng của bạn" 
                                   FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- CPU Frequency Card -->
                            <Border Grid.Column="1" Grid.Row="0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="⚡" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Tần số CPU" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Current Status -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Tối thiểu hiện tại:" FontSize="11" Foreground="#666"/>
                                            <TextBlock x:Name="CurrentMinCpuFreq" Text="Không xác định" FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Tối đa hiện tại:" FontSize="11" Foreground="#666"/>
                                            <TextBlock x:Name="CurrentMaxCpuFreq" Text="Không xác định" FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Frequency Controls -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tối thiểu:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="MinFrequencyTextBox" Text="25" Margin="0,0,8,5"/>
                                        <Button Grid.Row="0" Grid.Column="2" Content="Áp dụng" Click="SetMinCpuFrequency_Click" Width="60" Margin="0,0,0,5"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Tối đa:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="MaxFrequencyTextBox" Text="100" Margin="0,0,8,0"/>
                                        <Button Grid.Row="1" Grid.Column="2" Content="Áp dụng" Click="SetMaxCpuFrequency_Click" Width="60"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Smart Control Card -->
                            <Border Grid.Column="0" Grid.Row="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="🤖" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Điều khiển Thông minh" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock x:Name="AutoAdjustStatus" 
                                   Text="Điều chỉnh tự động đã tắt" 
                                   FontSize="12" Foreground="#666" Margin="0,0,0,12"/>

                                    <Button x:Name="AutoAdjustCpuButton" 
                                Content="🚀 Bật Chế độ Thông minh" 
                                Click="AutoAdjustCpuButton_Click" 
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,10"/>

                                    <Border Background="#F8F9FA" CornerRadius="6" Padding="10">
                                        <StackPanel>
                                            <TextBlock Text="Chế độ Thông minh tự động điều chỉnh tần số CPU dựa trên mức sử dụng:" 
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                            <TextBlock Text="• Sử dụng thấp (0-30%): Chế độ tiết kiệm điện" FontSize="10" Margin="0,2"/>
                                            <TextBlock Text="• Sử dụng vừa (30-70%): Chế độ cân bằng" FontSize="10" Margin="0,2"/>
                                            <TextBlock Text="• Sử dụng cao (70%+): Chế độ hiệu suất" FontSize="10" Margin="0,2"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Sleep and Display Card -->
                            <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="💤" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Ngủ và Hiển thị" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Screen Off -->
                                        <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="📺" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Tắt màn hình sau" VerticalAlignment="Center" Width="120"/>
                                            <TextBox x:Name="ScreenOffMinutesTextBox" Text="10" Width="40" Margin="5,0"/>
                                            <TextBlock Text="phút" VerticalAlignment="Center" Margin="5,0,8,0"/>
                                            <Button Content="Áp dụng" Click="ApplyScreenOffTime_Click" Width="60"/>
                                        </StackPanel>

                                        <!-- Sleep -->
                                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal">
                                            <TextBlock Text="😴" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Ngủ sau" VerticalAlignment="Center" Width="120"/>
                                            <TextBox x:Name="SleepMinutesTextBox" Text="30" Width="40" Margin="5,0"/>
                                            <TextBlock Text="phút" VerticalAlignment="Center" Margin="5,0,8,0"/>
                                            <Button Content="Áp dụng" Click="ApplySleepTime_Click" Width="60"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="⚠️ Cảnh báo hệ thống" Style="{StaticResource TabButtonStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <Border Style="{StaticResource CardStyle}" Background="White" 
                BorderBrush="#E0E6ED" BorderThickness="1">
                        <StackPanel Margin="30">
                            <!-- Header Section -->
                            <Grid x:Name="HeaderSection" Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="⚠️ Cài đặt cảnh báo hệ thống" 
                                   FontSize="24" FontWeight="Bold" 
                                   Foreground="#1565C0" Margin="0,0,0,8"/>
                                    <TextBlock Text="Điều chỉnh ngưỡng cảnh báo để theo dõi hiệu suất hệ thống tối ưu" 
                                   FontSize="14" Foreground="#666" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Button Grid.Column="1" Content="💾 Lưu cài đặt" 
                            Click="SaveWarningSettings_Click"
                            Background="#4CAF50" Foreground="White"
                            BorderBrush="#4CAF50" BorderThickness="1"
                            Padding="16,10" FontWeight="SemiBold"
                            MinWidth="130" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Settings Grid -->
                            <Grid x:Name="SettingsGrid" Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- CPU Settings -->
                                <GroupBox Header="🖥️ Bộ xử lý (CPU)" Grid.Column="0" Grid.Row="0" 
                              Margin="0,0,15,15" Padding="20" 
                              Background="#F8FAFC" BorderBrush="#CBD5E1" 
                              BorderThickness="1">
                                    <StackPanel>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="Sử dụng:" Grid.Column="0" 
                                       VerticalAlignment="Center" FontWeight="Medium"/>
                                            <TextBox x:Name="CpuThresholdTextBox" Grid.Column="1" 
                                         Text="85" Padding="5" BorderBrush="#CBD5E1"
                                         Background="White"/>
                                            <TextBlock Text="%" Grid.Column="2" 
                                          VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </Grid>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="Nhiệt độ:" Grid.Column="0" 
                                       VerticalAlignment="Center" FontWeight="Medium"/>
                                            <TextBox x:Name="CpuTempThresholdTextBox" Grid.Column="1" 
                                         Text="80" Padding="5" BorderBrush="#CBD5E1"
                                         Background="White"/>
                                            <TextBlock Text="°C" Grid.Column="2" 
                                          VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </GroupBox>

                                <!-- RAM Settings -->
                                <GroupBox Header="💾 Bộ nhớ (RAM)" Grid.Column="1" Grid.Row="0" 
                              Margin="15,0,0,15" Padding="20"
                              Background="#F8FAFC" BorderBrush="#CBD5E1" 
                              BorderThickness="1">
                                    <StackPanel>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="Sử dụng:" Grid.Column="0" 
                                       VerticalAlignment="Center" FontWeight="Medium"/>
                                            <TextBox x:Name="RamThresholdTextBox" Grid.Column="1" 
                                         Text="90" Padding="5" BorderBrush="#CBD5E1"
                                         Background="White"/>
                                            <TextBlock Text="%" Grid.Column="2" 
                                          VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </GroupBox>

                                <!-- GPU Settings -->
                                <GroupBox Header="🎮 Card đồ họa (GPU)" Grid.Column="0" Grid.Row="1" 
                              Margin="0,0,15,0" Padding="20"
                              Background="#F8FAFC" BorderBrush="#CBD5E1" 
                              BorderThickness="1">
                                    <StackPanel>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="Sử dụng:" Grid.Column="0" 
                                       VerticalAlignment="Center" FontWeight="Medium"/>
                                            <TextBox x:Name="GpuThresholdTextBox" Grid.Column="1" 
                                         Text="85" Padding="5" BorderBrush="#CBD5E1"
                                         Background="White"/>
                                            <TextBlock Text="%" Grid.Column="2" 
                                          VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </Grid>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="Nhiệt độ:" Grid.Column="0" 
                                       VerticalAlignment="Center" FontWeight="Medium"/>
                                            <TextBox x:Name="GpuTempThresholdTextBox" Grid.Column="1" 
                                         Text="85" Padding="5" BorderBrush="#CBD5E1"
                                         Background="White"/>
                                            <TextBlock Text="°C" Grid.Column="2" 
                                          VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </GroupBox>

                                <!-- Disk Settings -->
                                <GroupBox Header="💽 Ổ cứng (Disk)" Grid.Column="1" Grid.Row="1" 
                              Margin="15,0,0,0" Padding="20"
                              Background="#F8FAFC" BorderBrush="#CBD5E1" 
                              BorderThickness="1">
                                    <StackPanel>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="Hoạt động:" Grid.Column="0" 
                                       VerticalAlignment="Center" FontWeight="Medium"/>
                                            <TextBox x:Name="DiskThresholdTextBox" Grid.Column="1" 
                                         Text="95" Padding="5" BorderBrush="#CBD5E1"
                                         Background="White"/>
                                            <TextBlock Text="%" Grid.Column="2" 
                                          VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </GroupBox>
                            </Grid>

                            <!-- Status Section -->
                            <Border x:Name="StatusSection" Background="#E8F5E8" BorderBrush="#4CAF50" BorderThickness="1" 
                        Padding="15" Margin="0,0,0,25">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✅" FontSize="16" Margin="0,0,10,0" 
                                   VerticalAlignment="Center"/>
                                    <TextBlock x:Name="WarningSettingsStatus" 
                                   Text="Cảnh báo đang hoạt động với ngưỡng mặc định" 
                                   Foreground="#2E7D32" FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Solutions Toggle Button -->
                            <StackPanel x:Name="ToggleButtonSection" HorizontalAlignment="Center">
                                <Button x:Name="ShowSolutionsButton" Content="💡 Hiển thị giải pháp" 
                            Click="ShowSolutions_Click" 
                            Background="#FF9800" Foreground="White" BorderBrush="#FF9800"
                            Padding="20,12" FontWeight="SemiBold"
                            MinWidth="180" Margin="0,0,0,15"/>

                                <Button x:Name="HideSolutionsButton" Content="⚙️ Quay lại cài đặt" 
                            Click="HideSolutions_Click" 
                            Background="#6C757D" Foreground="White" BorderBrush="#6C757D"
                            Padding="20,12" FontWeight="SemiBold"
                            MinWidth="180" Margin="0,0,0,15"
                            Visibility="Collapsed"/>
                            </StackPanel>

                            <!-- Solutions Header -->
                            <Grid x:Name="SolutionsHeader" Margin="0,10,0,15" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🛠️ Giải pháp khắc phục sự cố" 
                                   FontSize="24" FontWeight="Bold" 
                                   Foreground="#1565C0" Margin="0,0,0,8"/>
                                    <TextBlock Text="Chọn giải pháp phù hợp để khắc phục các vấn đề về hiệu suất hệ thống" 
                                   FontSize="14" Foreground="#666" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Border Grid.Column="1" Background="#FFF3E0" BorderBrush="#FF9800" 
                            BorderThickness="1" Padding="12,8" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚡" FontSize="16" Margin="0,0,8,0" 
                                       VerticalAlignment="Center"/>
                                        <TextBlock Text="Chế độ giải pháp nhanh" 
                                       Foreground="#E65100" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Solutions Panel -->
                            <ScrollViewer x:Name="SolutionsPanel" MaxHeight="300" 
                              VerticalScrollBarVisibility="Auto" 
                              Visibility="Collapsed">
                                <Border Background="#F8FAFC" BorderBrush="#E0E6ED" 
                            BorderThickness="1" Padding="15">
                                    <ItemsControl x:Name="SolutionsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" BorderBrush="#E0E6ED" 
                                            BorderThickness="1" Margin="0,0,0,15" Padding="20">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Solution Content -->
                                                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                                <Border Background="#F0F8FF" Padding="8" Margin="0,0,12,0">
                                                                    <TextBlock Text="{Binding Icon}" FontSize="16"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                                               FontSize="16" VerticalAlignment="Center" 
                                                               Foreground="#1565C0"/>
                                                            </StackPanel>

                                                            <TextBlock Text="{Binding Description}" 
                                                           TextWrapping="Wrap" Margin="0,0,0,10" 
                                                           FontSize="14" Foreground="#475569"/>

                                                            <TextBlock Text="{Binding Action}" 
                                                           Foreground="#64748B" FontSize="13" 
                                                           TextWrapping="Wrap" FontStyle="Italic"/>
                                                        </StackPanel>

                                                        <!-- Action Buttons -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <Button Content="🚀 Thực hiện" 
                                                        Background="#4CAF50" Foreground="White"
                                                        BorderBrush="#4CAF50" BorderThickness="1"
                                                        Padding="16,8" Margin="0,0,0,8"
                                                        FontSize="12" FontWeight="SemiBold"
                                                        MinWidth="110"
                                                        Click="QuickAction_Click" Tag="{Binding}"
                                                        ToolTip="Thực hiện giải pháp ngay"/>

                                                            <Button Content="📖 Hướng dẫn" 
                                                        Background="#2196F3" Foreground="White"
                                                        BorderBrush="#2196F3" BorderThickness="1"
                                                        Padding="16,8" FontSize="12" FontWeight="SemiBold"
                                                        MinWidth="110"
                                                        Click="ShowGuide_Click" Tag="{Binding}"
                                                        ToolTip="Xem hướng dẫn chi tiết"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="🔄 Giám sát tiến trình" Style="{StaticResource TabButtonStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="🔄 Giám sát tiến trình" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                            <!-- Control buttons -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Button Content="🔄 Làm mới" Width="100" Click="RefreshProcessList_Click"/>
                                <Button Content="▶ Bắt đầu giám sát" Width="120" Click="StartProcessMonitor_Click"/>
                                <Button Content="⏹ Dừng giám sát" Width="120" Click="StopProcessMonitor_Click"/>
                            </StackPanel>

                            <!-- Process count -->
                            <TextBlock x:Name="ProcessCountLabel" 
                           Text="Tổng số tiến trình: 0" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,10"/>

                            <!-- Process list -->
                            <ListView x:Name="ProcessListView" 
                          Height="400" 
                          GridViewColumnHeader.Click="ProcessListView_ColumnHeaderClick"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">

                                <!-- Context Menu for ListView -->
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="🔄 Làm mới danh sách tiến trình" Click="RefreshProcessList_Click"/>
                                        <Separator/>
                                        <MenuItem Header="⚠️ Kết thúc tiến trình" Click="EndProcess_ContextMenu_Click"/>
                                        <Separator/>
                                        <MenuItem Header="🎛️ Đặt giới hạn tài nguyên" Click="SetResourceLimit_ContextMenu_Click"/>
                                        <MenuItem Header="🚫 Xóa giới hạn tài nguyên" Click="RemoveResourceLimit_ContextMenu_Click"/>
                                        <Separator/>
                                        <MenuItem Header="📊 Xem tất cả giới hạn tài nguyên" Click="ViewResourceLimits_Click"/>
                                        <Separator/>
                                    </ContextMenu>
                                </ListView.ContextMenu>

                                <ListView.View>
                                    <GridView>
                                        <!-- Icon and Process Name column combined -->
                                        <GridViewColumn Header="Tiến trình" Width="250">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="{Binding Icon}" 
                                                   Width="16" 
                                                   Height="16" 
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}" 
                                                       VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="ID" Width="60" DisplayMemberBinding="{Binding Id}"/>
                                        <GridViewColumn Header="Bộ nhớ (MB)" Width="120" DisplayMemberBinding="{Binding MemoryUsageText}"/>
                                        <GridViewColumn Header="CPU (%)" Width="80" DisplayMemberBinding="{Binding CpuUsageText}"/>
                                        <GridViewColumn Header="Trạng thái" Width="150" DisplayMemberBinding="{Binding Status}"/>
                                        <!-- Thêm cột Priority -->
                                        <GridViewColumn Header="Ưu tiên" Width="100" DisplayMemberBinding="{Binding PriorityText}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <TextBlock Text="⚠️ Cảnh báo: Hãy cẩn thận khi kết thúc tiến trình hoặc thay đổi ưu tiên, điều này có thể ảnh hưởng đến hệ thống!" 
                           Foreground="Orange" 
                           FontWeight="SemiBold" 
                           Margin="0,10,0,0" 
                           TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>