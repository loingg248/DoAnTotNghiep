<Window x:Class="SystemMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:lv="clr-namespace:LiveCharts;assembly=LiveCharts"
        Title="System Monitor" Height="780" Width="1000"
        Background="#FFF0F2F5" FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <!-- Card style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Direction="270" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button style -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF1976D2"/>
            <Setter Property="BorderBrush" Value="#FF1976D2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="6"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" 
                                BorderThickness="0,0,0,2" BorderBrush="Transparent" 
                                Margin="{TemplateBinding Margin}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" 
                                              HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#1976D2"/>
                                <Setter Property="Foreground" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1976D2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Chart Card Style - Điều chỉnh kích thước nhỏ hơn và đảm bảo hiển thị -->
        <Style x:Key="ChartCardStyle" TargetType="lvc:CartesianChart">
            <Setter Property="Height" Value="180"/>
            <Setter Property="MinHeight" Value="150"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="DisableAnimations" Value="False"/>
            <Setter Property="Hoverable" Value="True"/>
            <Setter Property="AnimationsSpeed" Value="00:00:00.8"/>
            <Setter Property="Background" Value="#FAFBFC"/>
        </Style>    
    </Window.Resources>

    <DockPanel>
        <Border x:Name="WarningBorder" 
        DockPanel.Dock="Top" 
        Margin="15,10,15,10" 
        Padding="15,10" 
        CornerRadius="8"
        Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="WarningStatus" 
                   Text="Hệ thống hoạt động bình thường" 
                   FontWeight="SemiBold" 
                   VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tab Control for different pages -->
        <TabControl Margin="10" BorderThickness="0" Background="Transparent">
            <TabItem Header="🖥️ Thông số hệ thống" Style="{StaticResource TabButtonStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Control buttons moved here -->
                        <StackPanel Orientation="Horizontal" Margin="15" HorizontalAlignment="Left">
                            <Button Content="🔄 Refresh" Width="110" Click="RefreshButton_Click"/>
                            <Button Content="▶ Start Monitor" Width="140" Click="StartMonitorButton_Click"/>
                            <Button Content="⏹ Stop Monitor" Width="140" Click="StopMonitorButton_Click"/>
                        </StackPanel>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- CPU Card -->
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="🖥 CPU" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="CpuName" Text="CPU Name: " Margin="0,3"/>
                                    <TextBlock x:Name="CpuTemp" Text="CPU Temperature: " Margin="0,3"/>
                                    <TextBlock x:Name="CpuLoad" Text="CPU Usage: " Margin="0,3"/>
                                    <TextBlock x:Name="CpuClock" Text="CPU Clock: " Margin="0,3"/>

                                    <!-- Biểu đồ CPU với trục được định nghĩa rõ ràng -->
                                    <lvc:CartesianChart x:Name="CpuChart" Style="{StaticResource ChartCardStyle}">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="" ShowLabels="False" Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="%" MinValue="0" MaxValue="100" 
              LabelFormatter="{Binding YFormatter}"
              Separator="{x:Static lvc:DefaultAxes.CleanSeparator}">
                                                <lvc:Axis.Sections>
                                                    <lvc:AxisSection Value="0" SectionWidth="30" Fill="#E8F5E8"/>
                                                    <lvc:AxisSection Value="30" SectionWidth="40" Fill="#FFF3CD"/>
                                                    <lvc:AxisSection Value="70" SectionWidth="30" Fill="#F8D7DA"/>
                                                </lvc:Axis.Sections>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.Series>
                                            <lvc:LineSeries Values="{Binding CpuValues}" 
                        StrokeThickness="3" 
                        PointGeometrySize="6"
                        Fill="#331976D2"
                        Stroke="#1976D2"/>
                                        </lvc:CartesianChart.Series>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>

                            <!-- RAM Card -->
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="💾 Memory" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="RamTotal" Text="Total RAM: " Margin="0,3"/>
                                    <TextBlock x:Name="RamUsed" Text="Used RAM: " Margin="0,3"/>
                                    <TextBlock x:Name="RamAvailable" Text="Available RAM: " Margin="0,3"/>
                                    <TextBlock x:Name="RamUsage" Text="RAM Usage: " Margin="0,3"/>

                                    <!-- Biểu đồ RAM với trục được định nghĩa rõ ràng -->
                                    <lvc:CartesianChart x:Name="RamChart" Style="{StaticResource ChartCardStyle}">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="" ShowLabels="False" Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="%" MinValue="0" MaxValue="100" 
              LabelFormatter="{Binding YFormatter}"
              Separator="{x:Static lvc:DefaultAxes.CleanSeparator}">
                                                <lvc:Axis.Sections>
                                                    <lvc:AxisSection Value="0" SectionWidth="50" Fill="#E8F5E8"/>
                                                    <lvc:AxisSection Value="50" SectionWidth="30" Fill="#FFF3CD"/>
                                                    <lvc:AxisSection Value="80" SectionWidth="20" Fill="#F8D7DA"/>
                                                </lvc:Axis.Sections>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.Series>
                                            <lvc:LineSeries Values="{Binding RamValues}" 
                        StrokeThickness="3" 
                        PointGeometrySize="6"
                        Fill="#334CAF50"
                        Stroke="#4CAF50"/>
                                        </lvc:CartesianChart.Series>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>

                            <!-- GPU Card -->
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardStyle}">
                                <StackPanel x:Name="GpuContainer" Grid.Row="2" Grid.Column="1" Margin="10,10,10,10">
                                    <TextBlock Text="🎮 GPU" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="GpuName" Text="GPU Name: " Margin="0,3"/>
                                    <TextBlock x:Name="GpuTemp" Text="GPU Temperature: " Margin="0,3"/>
                                    <TextBlock x:Name="GpuLoad" Text="GPU Usage: " Margin="0,3"/>
                                    <TextBlock x:Name="GpuMemory" Text="GPU Memory: " Margin="0,3"/>

                                    <!-- Biểu đồ GPU với trục được định nghĩa rõ ràng -->
                                    <lvc:CartesianChart x:Name="GpuChart" Style="{StaticResource ChartCardStyle}">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="" ShowLabels="False" Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="%" MinValue="0" MaxValue="100" 
              LabelFormatter="{Binding YFormatter}"
              Separator="{x:Static lvc:DefaultAxes.CleanSeparator}">
                                                <lvc:Axis.Sections>
                                                    <lvc:AxisSection Value="0" SectionWidth="30" Fill="#E8F5E8"/>
                                                    <lvc:AxisSection Value="30" SectionWidth="40" Fill="#FFF3CD"/>
                                                    <lvc:AxisSection Value="70" SectionWidth="30" Fill="#F8D7DA"/>
                                                </lvc:Axis.Sections>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.Series>
                                            <lvc:LineSeries Values="{Binding GpuValues}" 
                        StrokeThickness="3" 
                        PointGeometrySize="6"
                        Fill="#33FF9800"
                        Stroke="#FF9800"/>
                                        </lvc:CartesianChart.Series>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>

                            <!-- Disk Card -->
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="💽 Disk" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="DiskName" Text="Disk Name: " Margin="0,3"/>
                                    <TextBlock x:Name="DiskTemp" Text="Disk Temperature: " Margin="0,3"/>
                                    <TextBlock x:Name="DiskActivity" Text="Disk Activity: " Margin="0,3"/>
                                    <TextBlock x:Name="DiskSpace" Text="Disk Space: " Margin="0,3"/>

                                    <!-- Biểu đồ Disk với trục được định nghĩa rõ ràng -->
                                    <lvc:CartesianChart x:Name="DiskChart" Style="{StaticResource ChartCardStyle}">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="" ShowLabels="False" Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="%" MinValue="0" MaxValue="100" 
              LabelFormatter="{Binding YFormatter}"
              Separator="{x:Static lvc:DefaultAxes.CleanSeparator}">
                                                <lvc:Axis.Sections>
                                                    <lvc:AxisSection Value="0" SectionWidth="50" Fill="#E8F5E8"/>
                                                    <lvc:AxisSection Value="50" SectionWidth="30" Fill="#FFF3CD"/>
                                                    <lvc:AxisSection Value="80" SectionWidth="20" Fill="#F8D7DA"/>
                                                </lvc:Axis.Sections>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.Series>
                                            <lvc:LineSeries Values="{Binding DiskValues}" 
                        StrokeThickness="3" 
                        PointGeometrySize="6"
                        Fill="#339C27B0"
                        Stroke="#9C27B0"/>
                                        </lvc:CartesianChart.Series>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="⚙️ Power Settings" Style="{StaticResource TabButtonStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <TextBlock Text="⚙️" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Power Management" FontSize="22" FontWeight="Bold" Foreground="#1976D2"/>
                                <TextBlock Text="Optimize your system power consumption and performance" 
                               FontSize="13" Foreground="#666" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Power Plan Card -->
                            <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="🔋" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Power Plan" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <ComboBox x:Name="PowerPlanComboBox" 
                                  SelectionChanged="PowerPlanComboBox_SelectionChanged"
                                  Margin="0,0,0,10"/>

                                    <TextBlock Text="Select the power plan that best fits your usage pattern" 
                                   FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- CPU Frequency Card -->
                            <Border Grid.Column="1" Grid.Row="0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="⚡" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="CPU Frequency" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Current Status -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Current Min:" FontSize="11" Foreground="#666"/>
                                            <TextBlock x:Name="CurrentMinCpuFreq" Text="N/A" FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Current Max:" FontSize="11" Foreground="#666"/>
                                            <TextBlock x:Name="CurrentMaxCpuFreq" Text="N/A" FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Frequency Controls -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Min:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="MinFrequencyTextBox" Text="25" Margin="0,0,8,5"/>
                                        <Button Grid.Row="0" Grid.Column="2" Content="Set" Click="SetMinCpuFrequency_Click" Width="50" Margin="0,0,0,5"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Max:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="MaxFrequencyTextBox" Text="100" Margin="0,0,8,0"/>
                                        <Button Grid.Row="1" Grid.Column="2" Content="Set" Click="SetMaxCpuFrequency_Click" Width="50"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Smart Control Card -->
                            <Border Grid.Column="0" Grid.Row="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="🤖" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Smart Control" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock x:Name="AutoAdjustStatus" 
                                   Text="Automatic adjustment is disabled" 
                                   FontSize="12" Foreground="#666" Margin="0,0,0,12"/>

                                    <Button x:Name="AutoAdjustCpuButton" 
                                Content="🚀 Enable Smart Mode" 
                                Click="AutoAdjustCpuButton_Click" 
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,10"/>

                                    <Border Background="#F8F9FA" CornerRadius="6" Padding="10">
                                        <StackPanel>
                                            <TextBlock Text="Smart Mode automatically adjusts CPU frequency based on usage:" 
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                            <TextBlock Text="• Low usage (0-30%): Power saving mode" FontSize="10" Margin="0,2"/>
                                            <TextBlock Text="• Medium usage (30-70%): Balanced mode" FontSize="10" Margin="0,2"/>
                                            <TextBlock Text="• High usage (70%+): Performance mode" FontSize="10" Margin="0,2"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Sleep and Display Card -->
                            <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="💤" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Sleep and Display" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Screen Off -->
                                        <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="📺" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Turn off display after" VerticalAlignment="Center" Width="120"/>
                                            <TextBox x:Name="ScreenOffMinutesTextBox" Text="10" Width="40" Margin="5,0"/>
                                            <TextBlock Text="min" VerticalAlignment="Center" Margin="5,0,8,0"/>
                                            <Button Content="Apply" Click="ApplyScreenOffTime_Click" Width="60"/>
                                        </StackPanel>

                                        <!-- Sleep -->
                                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal">
                                            <TextBlock Text="😴" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Sleep after" VerticalAlignment="Center" Width="120"/>
                                            <TextBox x:Name="SleepMinutesTextBox" Text="30" Width="40" Margin="5,0"/>
                                            <TextBlock Text="min" VerticalAlignment="Center" Margin="5,0,8,0"/>
                                            <Button Content="Apply" Click="ApplySleepTime_Click" Width="60"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="⚠️ Cảnh Báo" Style="{StaticResource TabButtonStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="⚠️ Cài Đặt Cảnh Báo Hệ Thống" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                            <TextBlock Text="Điều chỉnh ngưỡng cảnh báo cho các thành phần hệ thống:" 
                           Margin="0,0,0,15" TextWrapping="Wrap"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- CPU Settings -->
                                <GroupBox Header="🖥️ CPU" Grid.Column="0" Grid.Row="0" Margin="5">
                                    <StackPanel Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="0,5">
                                            <Label Content="Mức sử dụng (%):" Width="120"/>
                                            <TextBox x:Name="CpuThresholdTextBox" Width="60" Text="85"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,5">
                                            <Label Content="Nhiệt độ (°C):" Width="120"/>
                                            <TextBox x:Name="CpuTempThresholdTextBox" Width="60" Text="80"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>

                                <!-- RAM Settings -->
                                <GroupBox Header="💾 RAM" Grid.Column="1" Grid.Row="0" Margin="5">
                                    <StackPanel Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="0,5">
                                            <Label Content="Mức sử dụng (%):" Width="120"/>
                                            <TextBox x:Name="RamThresholdTextBox" Width="60" Text="90"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>

                                <!-- GPU Settings -->
                                <GroupBox Header="🎮 GPU" Grid.Column="0" Grid.Row="1" Margin="5">
                                    <StackPanel Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="0,5">
                                            <Label Content="Mức sử dụng (%):" Width="120"/>
                                            <TextBox x:Name="GpuThresholdTextBox" Width="60" Text="85"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,5">
                                            <Label Content="Nhiệt độ (°C):" Width="120"/>
                                            <TextBox x:Name="GpuTempThresholdTextBox" Width="60" Text="85"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>

                                <!-- Disk Settings -->
                                <GroupBox Header="💽 Disk" Grid.Column="1" Grid.Row="1" Margin="5">
                                    <StackPanel Margin="10">
                                        <StackPanel Orientation="Horizontal" Margin="0,5">
                                            <Label Content="Hoạt động (%):" Width="120"/>
                                            <TextBox x:Name="DiskThresholdTextBox" Width="60" Text="95"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </Grid>

                            <Button Content="💾 Lưu Cài Đặt" 
                        Click="SaveWarningSettings_Click" 
                        HorizontalAlignment="Center" 
                        Margin="0,20,0,0" 
                        Width="150"/>

                            <Separator Margin="0,20"/>

                            <TextBlock Text="📋 Trạng Thái Cảnh Báo:" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock x:Name="WarningSettingsStatus" 
                           Text="Cảnh báo đang hoạt động với ngưỡng mặc định" 
                           Foreground="Green"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="🔄 Process Monitor" Style="{StaticResource TabButtonStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="🔄 Theo dõi Process" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                            <!-- Control buttons -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Button Content="🔄 Refresh" Width="100" Click="RefreshProcessList_Click"/>
                                <Button Content="▶ Start Monitor" Width="120" Click="StartProcessMonitor_Click"/>
                                <Button Content="⏹ Stop Monitor" Width="120" Click="StopProcessMonitor_Click"/>
                            </StackPanel>

                            <!-- Process count -->
                            <TextBlock x:Name="ProcessCountLabel" 
                           Text="Tổng số process: 0" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,10"/>

                            <!-- Process list -->
                            <ListView x:Name="ProcessListView" 
          Height="400" 
          GridViewColumnHeader.Click="ProcessListView_ColumnHeaderClick"
          ScrollViewer.HorizontalScrollBarVisibility="Auto">

                                <!-- Context Menu cho ListView -->
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="❌ End Process" Click="EndProcess_ContextMenu_Click"/>
                                    </ContextMenu>
                                </ListView.ContextMenu>

                                <ListView.View>
                                    <GridView>
                                        <!-- Cột Icon và Tên Process được gộp lại -->
                                        <GridViewColumn Header="Process" Width="250">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="{Binding Icon}" 
                                   Width="16" 
                                   Height="16" 
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}" 
                                       VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="ID" Width="60" DisplayMemberBinding="{Binding Id}"/>
                                        <GridViewColumn Header="Memory (MB)" Width="120" DisplayMemberBinding="{Binding MemoryUsageText}"/>
                                        <GridViewColumn Header="CPU (%)" Width="80" DisplayMemberBinding="{Binding CpuUsageText}"/>
                                        <GridViewColumn Header="Trạng thái" Width="150" DisplayMemberBinding="{Binding Status}"/>
                                        <!-- Đã xóa cột "Hành động" với nút Kill -->
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <TextBlock Text="⚠️ Lưu ý: Hãy cẩn thận khi kết thúc process, có thể ảnh hưởng đến hệ thống!" 
                           Foreground="Orange" 
                           FontWeight="SemiBold" 
                           Margin="0,10,0,0" 
                           TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="🚀 Startup Manager" Style="{StaticResource TabButtonStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="🚀 Quản Lý Startup" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                            <TextBlock Text="Quản lý các chương trình khởi động cùng Windows để tăng tốc độ boot và tiết kiệm tài nguyên hệ thống." 
                           Margin="0,0,0,15" TextWrapping="Wrap" Foreground="Gray"/>

                            <!-- Control buttons -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Button Content="🔄 Refresh" Width="100" Click="RefreshStartupList_Click"/>
                                <Button Content="❌ Disable" Width="100" Click="DisableStartupItem_Click"/>
                                <Button Content="✅ Enable" Width="100" Click="EnableStartupItem_Click"/>
                            </StackPanel>

                            <!-- Startup count -->
                            <TextBlock x:Name="StartupCountLabel" 
                           Text="Tổng số startup items: 0" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,10"/>

                            <!-- Startup items list -->
                            <ListView x:Name="StartupListView" 
                          Height="400" 
                          GridViewColumnHeader.Click="StartupListView_ColumnHeaderClick"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">

                                <!-- Context Menu cho ListView -->
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="❌ Disable" Click="DisableStartupItem_ContextMenu_Click"/>
                                        <MenuItem Header="✅ Enable" Click="EnableStartupItem_ContextMenu_Click"/>
                                        <Separator/>
                                        <MenuItem Header="📁 Open File Location" Click="OpenFileLocation_ContextMenu_Click"/>
                                    </ContextMenu>
                                </ListView.ContextMenu>

                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                        <GridViewColumn Header="Status" Width="80">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Status}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Enabled">
                                                                        <Setter Property="Foreground" Value="Green"/>
                                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                                                        <Setter Property="Foreground" Value="Red"/>
                                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Publisher" Width="150" DisplayMemberBinding="{Binding Publisher}"/>
                                        <GridViewColumn Header="Description" Width="200" DisplayMemberBinding="{Binding Description}"/>
                                        <GridViewColumn Header="Location" Width="100" DisplayMemberBinding="{Binding Location}"/>
                                        <GridViewColumn Header="Type" Width="80" DisplayMemberBinding="{Binding Type}"/>
                                        <GridViewColumn Header="Command" Width="300" DisplayMemberBinding="{Binding Command}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <StackPanel Margin="0,15,0,0">
                                <TextBlock Text="💡 Mẹo:" FontWeight="SemiBold" Foreground="#1976D2"/>
                                <TextBlock Text="• Nhấp chuột phải vào item để xem menu tùy chọn" Margin="15,5,0,0"/>
                                <TextBlock Text="• Vô hiệu hóa các chương trình không cần thiết để tăng tốc khởi động" Margin="15,0,0,0"/>
                                <TextBlock Text="• Cẩn thận với các startup items của hệ thống" Margin="15,0,0,0"/>
                                <TextBlock Text="• Registry items không thể kích hoạt lại sau khi vô hiệu hóa" Margin="15,0,0,5" Foreground="Orange"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>